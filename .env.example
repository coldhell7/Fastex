# ==============================================================
# Medalino Project — Root Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ==============================================================
# These vars are shared across all packages/apps in the monorepo.
# For app-specific vars, see apps/admin/.env.example.
# ==============================================================

# ---------- Database ----------
DATABASE_URL=postgresql://localhost:5432/medalino

# ---------- Core URLs ----------
PUBLIC_ADMIN_URL=https://admin.medalino.ir
NEXT_PUBLIC_STOREFRONT_URL=https://medalino.ir

# ---------- Admin Auth ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=medalino
ADMIN_AUTH_SECRET=dev-admin-auth-secret-change-me

# ---------- AI Providers ----------
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_PROVIDER=openrouter

# ---------- Google Indexing API ----------
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=

# ---------- Redis (Upstash) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Node ----------
NODE_ENV=development
